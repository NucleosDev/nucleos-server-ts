{
    "name": "nucleos-backend",
    "version": "1.0.0",
    "description": "Backend completo para Nucleo App - Plataforma de Produtividade",
    "main": "dist/api/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/api/server.js",
        "dev": "npm run kill-port && tsx watch src/api/server.ts",
        "kill-port": "lsof -ti :5000 | xargs kill -9 || true",
        "dev:alt": "npm run kill-port && PORT=5001 tsx watch src/api/server.ts",
        "worker": "ts-node-dev --respawn --transpile-only src/jobs/xpWorker.ts",
        "worker:email": "ts-node-dev --respawn --transpile-only src/jobs/send-email.job.ts",
        "worker:ai": "ts-node-dev --respawn --transpile-only src/jobs/generate-insights.job.ts",
        "cron": "ts-node-dev --respawn --transpile-only src/jobs/cron.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "migrate": "ts-node-dev --transpile-only src/infrastructure/db/migrations/run.ts",
        "seed": "ts-node-dev --transpile-only src/infrastructure/db/migrations/seed.ts",
        "clean": "rm -rf dist",
        "rebuild": "npm run clean && npm run build",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.103.0",
        "bcrypt": "^5.1.1",
        "bcryptjs": "^3.0.3",
        "bull": "^4.16.5",
        "compression": "^1.8.1",
        "connect-timeout": "^1.9.1",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "express-rate-limit": "^7.5.1",
        "express-status-monitor": "^1.3.4",
        "express-validator": "^7.0.1",
        "helmet": "^7.2.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "nodemailer": "^6.10.1",
        "openai": "^4.20.1",
        "pg": "^8.20.0",
        "redis": "^4.7.1",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.6.2",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "typedi": "^0.10.0",
        "uuid": "^9.0.1",
        "winston": "^3.19.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/connect-timeout": "^1.9.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-rate-limit": "^5.1.3",
        "@types/helmet": "^0.0.48",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "@types/socket.io": "^3.0.1",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "eslint": "^10.2.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "pg-pool": "^3.13.0",
        "prettier": "^3.8.2",
        "supertest": "^6.3.4",
        "ts-jest": "^29.4.9",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.5.4"
    }
}
