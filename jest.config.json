{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": [
    "<rootDir>/src"
  ],
  "testMatch": [
    "**/__tests__/**/*.ts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleNameMapper": {
    "@domain/(.*)": "<rootDir>/src/domain/$1",
    "@application/(.*)": "<rootDir>/src/application/$1",
    "@infrastructure/(.*)": "<rootDir>/src/infrastructure/$1",
    "@presentation/(.*)": "<rootDir>/src/presentation/$1"
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/server.ts"
  ],
  "coverageDirectory": "coverage"
}