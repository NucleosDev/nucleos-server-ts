NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database (Supabase) - COLOQUE SEUS DADOS AQUI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Supabase Config
SUPABASE_HOST=db.YOUR_PROJECT.supabase.co
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USERNAME=postgres
SUPABASE_PASSWORD=YOUR_PASSWORD
SUPABASE_SSL=true

# JWT
JWT_KEY=YOUR_JWT_KEY_MIN_32_CHARS
JWT_SECRET=YOUR_JWT_SECRET
JWT_ISSUER=http://localhost:5000
JWT_AUDIENCE=http://localhost:5000
JWT_EXPIRES_MINUTES=90

# Redis (Docker)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS (Frontend)
CORS_ORIGINS=http://localhost:3000

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Email (MailHog local)
EMAIL_FROM=noreply@nucleos.local
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Produção (opcional)
# CORS_ORIGINS=https://nucleos-ui.vercel.app
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=200
